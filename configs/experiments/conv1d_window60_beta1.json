{
  "processed_windows_root": "dataset/processed_windows",
  "window_run_name": "latest",
  "model_output_root": "models/vae_runs",
  "vae_config": {
    "architecture": "conv1d",
    "latent_dim": 16,
    "conv_filters": [32, 64],
    "kernel_size": 3,
    "hidden_units": [64, 32],
    "encoder_use_batchnorm": false,
    "encoder_dropout_rate": 0.2
  },
  "train_config": {
    "epochs": 20,
    "batch_size": 512,
    "learning_rate": 0.001,
    "beta": 1.0,
    "validation_split": 0,
    "gradient_clipnorm": 1.0,
    "random_seed": 42,
    "verbose_epoch": true
  },
  "threshold_config": {
    "method": "val_f1",
    "percentile": 95.0,
    "std_factor": 3.0
  },
  "caps": {
    "max_train_windows": null,
    "max_val_windows": null,
    "max_test_windows": null
  }
}
